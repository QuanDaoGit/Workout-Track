        android:fillColor="#FFFFFFFF"
        android:pathData="M2,11 h20 v2 h-20 z M6,5 h3 v14 h-3 z M2.5,8 h2.5 v8 h-2.5 z M15,5 h3 v14 h-3 z M19,8 h2.5 v8 h-2.5 z" />

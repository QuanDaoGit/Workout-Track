# Miscellaneous
*.class
*.log
*.pyc
*.swp
.DS_Store
.atom/
.build/
.buildlog/
.history
.svn/
.swiftpm/
migrate_working_dir/

# IntelliJ related
*.iml
*.ipr
*.iws
.idea/

# The .vscode folder contains launch configuration and tasks you configure in
# VS Code which you may wish to be included in version control, so this line
# is commented out by default.
#.vscode/

# Flutter/Dart/Pub related — the Flutter project now lives under app/
**/doc/api/
**/ios/Flutter/.last_build_id
.dart_tool/
.flutter-plugins-dependencies
.pub-cache/
.pub/
/app/build/
/app/coverage/

# Symbolication related
app.*.symbols

# Obfuscation related
app.*.map.json

# Android Studio will place build artifacts here
/app/android/app/debug
/app/android/app/profile
/app/android/app/release

# Android signing — never commit keystore or key.properties
app/android/key.properties
*.jks
*.keystore

# Sentry — the auth token belongs in the SENTRY_AUTH_TOKEN env var, never in the
# repo. If you ever use the file fallback instead, keep it ignored.
app/android/sentry.properties
.sentryclirc

# Agent / tooling runtime — never commit
.codex_http.*
.codex_screenshot_runtime/
.codex/
# Machine-specific Codex runbook (the checked-in /deep-feature skill points here)
.claude/codex-local.md

# Windows shell metadata
desktop.ini
.claude/worktrees/

# /audit skill — throwaway rendered screenshots (regenerated per run)
app/test/audit/_shots/

# /audit-app skill — campaign run artifacts (ledger, per-unit findings, report)
audit-runs/

# Marketing video assets — large binaries belong in external storage, not git history
marketing/assets/promo-videos/

# Large binaries that don't belong in the repo (e.g. stray installers in screenshots)
*.exe
design/screenshots/*.exe

# Playwright MCP scratch output
.playwright-mcp/

# Large non-shipping media — keep out of git history (referenced only as design
# source / marketing, never bundled by pubspec). motivational_clips is ~1.9 GB.
# Relocated out of the app to their taxonomy homes (marketing/ + design/).
marketing/motivational_clips/
design/design_handoff_charge_ritual/
app/assets/design_handoff_session_ceremony/

# Firebase iOS config — kept out of git; inject it into the Codemagic build (or
# drop it in locally). The app still initializes Firebase from
# app/lib/firebase_options.dart, so a missing plist won't break the build.
app/ios/Runner/GoogleService-Info.plist
